--[[
    Premium Key System for Survive Zombie Arena
    Key: nhatmod
]]--

local ScreenGui = Instance.new("ScreenGui")
local MainFrame = Instance.new("Frame")
local UICorner = Instance.new("UICorner")
local UIStroke = Instance.new("UIStroke")
local Title = Instance.new("TextLabel")
local KeyInput = Instance.new("TextBox")
local SubmitBtn = Instance.new("TextButton")
local Status = Instance.new("TextLabel")

-- Setup Giao diện
ScreenGui.Name = "NhatMod_KeySystem"
ScreenGui.Parent = game:GetService("CoreGui")
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

MainFrame.Name = "MainFrame"
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
MainFrame.Position = UDim2.new(0.5, -110, 0.5, -80)
MainFrame.Size = UDim2.new(0, 220, 0, 160)
MainFrame.Active = true
MainFrame.Draggable = true -- Có thể di chuyển trên Mobile

UICorner.CornerRadius = UDim.new(0, 12)
UICorner.Parent = MainFrame

UIStroke.Thickness = 2
UIStroke.Color = Color3.fromRGB(60, 60, 60)
UIStroke.Parent = MainFrame

Title.Name = "Title"
Title.Parent = MainFrame
Title.BackgroundTransparency = 1
Title.Size = UDim2.new(1, 0, 0, 45)
Title.Font = Enum.Font.GothamBold
Title.Text = "NHATMOD AUTH"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextSize = 18

KeyInput.Name = "KeyInput"
KeyInput.Parent = MainFrame
KeyInput.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
KeyInput.Position = UDim2.new(0.1, 0, 0.35, 0)
KeyInput.Size = UDim2.new(0.8, 0, 0, 35)
KeyInput.Font = Enum.Font.Gotham
KeyInput.PlaceholderText = "Nhập Key tại đây..."
KeyInput.Text = ""
KeyInput.TextColor3 = Color3.fromRGB(255, 255, 255)
KeyInput.TextSize = 14
Instance.new("UICorner", KeyInput).CornerRadius = UDim.new(0, 8)

SubmitBtn.Name = "SubmitBtn"
SubmitBtn.Parent = MainFrame
SubmitBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
SubmitBtn.Position = UDim2.new(0.1, 0, 0.65, 0)
SubmitBtn.Size = UDim2.new(0.8, 0, 0, 40)
SubmitBtn.Font = Enum.Font.GothamBold
SubmitBtn.Text = "KÍCH HOẠT"
SubmitBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
SubmitBtn.TextSize = 14
Instance.new("UICorner", SubmitBtn).CornerRadius = UDim.new(0, 8)

Status.Name = "Status"
Status.Parent = MainFrame
Status.BackgroundTransparency = 1
Status.Position = UDim2.new(0, 0, 0.9, 0)
Status.Size = UDim2.new(1, 0, 0, 20)
Status.Font = Enum.Font.Gotham
Status.Text = "Status: Waiting..."
Status.TextColor3 = Color3.fromRGB(150, 150, 150)
Status.TextSize = 10

-- Logic xử lý
SubmitBtn.MouseButton1Click:Connect(function()
    local input = KeyInput.Text
    local correctKey = "nhatmod"
    
    if input == correctKey then
        Status.Text = "Key đúng! Đang tải script..."
        Status.TextColor3 = Color3.fromRGB(0, 255, 100)
        SubmitBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        SubmitBtn.Text = "SUCCESS"
        
        wait(1)
        ScreenGui:Destroy() -- Xóa menu key
        
        -- Chạy script Survive Zombie Arena
        loadstring(game:HttpGet("https://raw.githubusercontent.com/gumanba/Scripts/main/SurviveZombieArena"))()
    else
        Status.Text = "Sai key rồi bạn ơi!"
        Status.TextColor3 = Color3.fromRGB(255, 50, 50)
        SubmitBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        wait(1.5)
        SubmitBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
        SubmitBtn.Text = "KÍCH HOẠT"
        KeyInput.Text = ""
    end
end)
