local SectionMain = Tab:Section({
    Title = "Player Mods",
    TextSize = 18,
})

SectionMain:Button({
    Title = "fly v3 x",
    Callback = function()
        loadstring(game:HttpGet("https://rawscripts.net/raw/Universal-Script-Fly-V3-X-132770"))()
    end
})

SectionMain:Button({
    Title = "cụt chân, đầu",
    Callback = function()
        local player = game.Players.LocalPlayer
        local function showNotification()
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "Hệ thống Mod";
                Text = "Nhật Mod: Đã kích hoạt cụt chân phải & đầu!";
                Duration = 5;
            })
        end
        local function applyMod(character)
            local head = character:WaitForChild("Head", 5)
            if head then
                head.Transparency = 1
                if head:FindFirstChild("face") then
                    head.face.Transparency = 1
                end
            end
            local rightLegParts = {
                "RightFoot", "RightLowerLeg", "RightUpperLeg",
                "Right Leg"
            }
            for _, partName in pairs(rightLegParts) do
                local part = character:FindFirstChild(partName)
                if part and part:IsA("BasePart") then
                    part.Transparency = 1
                end
            end
        end
        if player.Character then
            showNotification()
            applyMod(player.Character)
        end
        player.CharacterAdded:Connect(function(character)
            task.wait(0.5)
            showNotification()
            applyMod(character)
        end)
    end
})

